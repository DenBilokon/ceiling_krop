# Copy this file to stretch_ceiling/.env for local development.
# Never commit real secrets.

HOST=0.0.0.0
PORT=8000
OPEN_BROWSER=1
ADMIN_PASSWORD=change-me-to-a-long-random-password
SESSION_SECRET=change-me-to-another-long-random-string

# Use these later when we connect Supabase/Netlify Functions.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWKS_URL=
SUPABASE_STORAGE_BUCKET=work-images
